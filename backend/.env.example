APP_NAME=GradingGuard AI
ENV=development
MOCK_LLM=true
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Local default uses SQLite. Use a separate disposable DB for tests.
SECURITY_DATABASE_URL=sqlite:///./.local/gradingguard_security.db
TEST_DATABASE_URL=

# Development placeholder only. Non-development environments must provide
# a long random value and must fail startup/review if this value is unchanged.
AUTH_TOKEN_SECRET=development-only-change-me
AUTH_ISSUER=gradingguard-local
AUTH_AUDIENCE=gradingguard-gateway

MAX_CANDIDATE_CONTENT_CHARS=12000
MAX_REQUEST_BODY_CHARS=20000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Student account auth (separate from operator console auth above)
STUDENT_TOKEN_SECRET=student-development-only-change-me
STUDENT_ACCESS_TOKEN_TTL_SECONDS=1800
STUDENT_REFRESH_TOKEN_TTL_SECONDS=604800
STUDENT_MAX_DEVICES=2

# Student login/register rate limiting (fixed-window, SQLite-backed)
STUDENT_LOGIN_MAX_ATTEMPTS_PER_EMAIL=5
STUDENT_LOGIN_WINDOW_SECONDS_PER_EMAIL=300
STUDENT_LOGIN_MAX_ATTEMPTS_PER_IP=20
STUDENT_LOGIN_WINDOW_SECONDS_PER_IP=300
STUDENT_REGISTER_MAX_ATTEMPTS_PER_IP=10
STUDENT_REGISTER_WINDOW_SECONDS_PER_IP=3600
